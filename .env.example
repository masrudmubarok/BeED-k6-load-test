# Copy to .env for reference. k6 does NOT auto-load .env — pass values with -e,
# e.g.  k6 run -e BEED_SID="..." main.js  (npm scripts via run.js DO load .env).
# Known gatekeeper hosts (load-test the TEST env, never production):
#   test  -> https://test-gatekeeper.beed.world/api   (default)
#   stage -> https://stage-gatekeeper.beed.world/api
#   local -> http://localhost:1010/api
BASE_URL=http://localhost:1010/api
BEED_SID=
VUS=25
DURATION=1m
SERVICES=experio,hub,library
